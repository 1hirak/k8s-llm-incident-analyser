# LLM provider selection: mock | openai | anthropic | deepseek
LLM_PROVIDER=mock

# Provider-specific API keys (required for non-mock providers)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=

# LLM parameters (optional)
LLM_MODEL=gpt-4o-mini
LLM_MAX_TOKENS=2000

# Feature flags
ENABLE_SCENARIOS=false
